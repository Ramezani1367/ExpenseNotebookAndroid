<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="14dp"
    android:paddingEnd="20dp"
    android:paddingTop="9dp"
    android:paddingBottom="9dp"
    android:background="@drawable/widget_bg">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="right|center_vertical"
        android:orientation="vertical">
        <TextView
            android:fontFamily="@font/vazirmatn"
            android:includeFontPadding="true"
            android:id="@+id/widget_date_primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="شنبه"
            android:textColor="#AAAAAA"
            android:textSize="11sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#e6e6e6"
            android:layout_marginTop="1dp"
            android:layout_marginBottom="1dp" />
        <TextView
            android:fontFamily="@font/vazirmatn"
            android:includeFontPadding="true"
            android:id="@+id/widget_date_secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="۱ تیر ۱۴۰۵"
            android:textColor="#1A5E3A"
            android:textSize="10.5sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">
            <TextView
                android:fontFamily="@font/vazirmatn"
                android:includeFontPadding="true"
                android:id="@+id/widget_gear"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:gravity="center"
                android:text="⚙"
                android:textColor="#888888"
                android:textSize="10sp" />
            <TextView
                android:fontFamily="@font/vazirmatn"
                android:includeFontPadding="true"
                android:id="@+id/widget_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:text="خرج کرد امروز"
                android:textColor="#888888"
                android:textSize="9.5sp" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">
            <TextView
                android:fontFamily="@font/vazirmatn"
                android:includeFontPadding="true"
                android:id="@+id/widget_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:text="۰"
                android:textColor="#1A5E3A"
                android:textSize="20sp"
                android:textStyle="bold" />
            <TextView
                android:fontFamily="@font/vazirmatn"
                android:includeFontPadding="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:text="تومان"
                android:textColor="#999999"
                android:textSize="9sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:fontFamily="@font/vazirmatn"
        android:includeFontPadding="true"
        android:id="@+id/widget_plus"
        android:clickable="true"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/widget_plus_bg"
        android:gravity="center"
        android:text="+"
        android:textColor="#FFFFFF"
        android:textSize="20sp" />
</LinearLayout>
